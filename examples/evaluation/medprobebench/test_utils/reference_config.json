{
  "pubmed": {
    "base_url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils",
    "rate_limit": 3,
    "timeout": 30,
    "max_retries": 3
  },
  "gpt": {
    "model": "gpt-4.1",
    "temperature": 0
  },
  "processing": {
    "file_level_workers": 2,
    "reference_level_workers": 5
  },
  "output": {
    "input_dir": "extracted_claims",
    "output_dir": "enriched_claims",
    "cache_dir": "cache"
  }
}
